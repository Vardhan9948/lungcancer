# Environment Configuration Template
# Copy this to .env and update values

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_APP=backend/app.py

# Secret Key (change this in production!)
SECRET_KEY=lungcare_ai_secret_key_2024_secure

# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite:///lungcare.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/lungcare

# Server Configuration
HOST=0.0.0.0
PORT=5000

# Security
MAX_CONTENT_LENGTH=16777216  # 16MB max file upload

# Admin User (auto-created on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@lungcare.ai

# Application Features
ENABLE_CHATBOT=True
ENABLE_IMAGE_ANALYSIS=True
ENABLE_CSV_ANALYSIS=True
